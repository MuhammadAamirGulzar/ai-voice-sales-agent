# Security
SESSION_MIDDLEWARE_SECRET_KEY=replace-with-long-random-secret
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-long-random-secret

# Database (sqlite default; use postgresql://... in production)
DATABASE_URL=sqlite:///./schema.db

# ── Streaming voice engine (outbound telephony) ─────────────────────────
# Deepgram: streaming STT (Nova-3) AND Aura TTS with one key.
# Free $200 signup credit at https://console.deepgram.com/signup
DEEPGRAM_API_KEY=replace-with-provider-key

# LLM — any OpenAI-compatible endpoint (Groq free tier recommended)
GROQ_API_KEY=replace-with-provider-key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# TTS: deepgram (Aura, default) or elevenlabs
TTS_PROVIDER=deepgram
TTS_VOICE=aura-2-thalia-en
ELEVENLABS_API_KEY=replace-with-provider-key

# STT / turn-taking tuning
STT_MODEL=nova-3
STT_LANGUAGE=multi
ENDPOINTING_MS=300
BARGE_IN_ENABLED=true
BARGE_IN_MODE=transcript

# ── Outbound calling (Twilio) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_PHONE_NUMBER=replace-with-twilio-phone-number
# Public HTTPS base Twilio can reach for webhooks (ngrok in dev)
PUBLIC_BASE_URL=
# Require X-API-Key on POST /api/outbound-call (recommended)
OUTBOUND_API_KEY=
# Answering-machine detection: voicemail drop instead of talking to a beep
MACHINE_DETECTION=false

# ── Production hardening ────────────────────────────────────────────────
# Reject Twilio webhooks (/outbound-voice, /outbound-status) whose
# X-Twilio-Signature doesn't verify against TWILIO_AUTH_TOKEN. Enable in
# production; requires PUBLIC_BASE_URL so the signed URL reconstructs.
TWILIO_VALIDATE_SIGNATURE=0
# Load shedding: above this many simultaneous calls, /api/outbound-call
# returns 429 instead of degrading every live conversation. 0 = unlimited.
MAX_CONCURRENT_CALLS=0
# Voice-engine log verbosity (DEBUG | INFO | WARNING)
LOG_LEVEL=INFO
# Human escalation target for the transfer_call tool (E.164)
TRANSFER_NUMBER=

# ── Legacy local pipeline / misc providers ──────────────────────────────
LLM_EC2_KEY=replace-with-provider-key

# Logging
LOG_FILE=response_times.log
PRINT_INFO=True
PRINT_ERROR=True
PRINT_WARNING=True

# Email notifications (optional)
SENDER_EMAIL=notifications@example.com
EMAIL_PASSWORD=replace-with-app-password

# Speech timing
TIMING=1
TIMING_PATH=speech_timing.csv
