# Security
SESSION_MIDDLEWARE_SECRET_KEY=replace-with-long-random-secret
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-long-random-secret

# LLM and speech providers
LLM_EC2_KEY=replace-with-provider-key
ELEVENLABS_API_KEY=replace-with-provider-key
DEEPGRAM_API_KEY=replace-with-provider-key

# Logging
LOG_FILE=response_times.log
PRINT_INFO=True
PRINT_ERROR=True
PRINT_WARNING=True

# Email notifications (optional)
SENDER_EMAIL=notifications@example.com
EMAIL_PASSWORD=replace-with-app-password

# Speech timing
TIMING=1
TIMING_PATH=speech_timing.csv
